{
  "name": "jericho-boado-portfolio",
  "version": "1.0.0",
  "description": "Professional PERN Portfolio Page",
  "main": "api/index.js",
  "scripts": {
    "install:client": "npm install --prefix client",
    "build:client": "npm install --prefix client && npm run build --prefix client",
    "dev:client": "npm run dev --prefix client",
    "start": "node api/index.js",
    "dev:server": "node --watch api/index.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
